{
  "output": {
    "filePath": "kb/full.xml",
    "style": "xml",
    "instructionFilePath": "kb/instructions.md"
  },
  "include": [
    "server/**/*.go",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "apps/desktop/src/**/*.ts",
    "apps/desktop/src/**/*.tsx",
    "apps/docs/content/**/*.mdx",
    "*.md",
    "*.json",
    "*.yaml",
    "Makefile",
    "scripts/*.sh"
  ],
  "ignore": {
    "customPatterns": [
      "server/pkg/db/generated/**",
      "server/migrations/**",
      "pnpm-lock.yaml",
      "**/*.tsbuildinfo",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.spec.ts",
      "**/vitest.config.*",
      "**/eslint.config.*"
    ]
  }
}
